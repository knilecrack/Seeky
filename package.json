{
  "name": "seeky",
  "displayName": "Seeky",
  "description": "Telescope-inspired modal search using ripgrep/fff — live grep and file finder with preview",
  "version": "0.0.1",
  "publisher": "knilecrack",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "ripgrep",
    "search",
    "telescope",
    "modal",
    "grep"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "seeky.grep",
        "title": "Live Grep",
        "category": "Seeky"
      },
      {
        "command": "seeky.findFiles",
        "title": "Find Files",
        "category": "Seeky"
      },
      {
        "command": "seeky.recentFiles",
        "title": "Recent Files",
        "category": "Seeky"
      },
      {
        "command": "seeky.openBuffers",
        "title": "Open Buffers",
        "category": "Seeky"
      },
      {
        "command": "seeky.documentSymbols",
        "title": "Document Symbols",
        "category": "Seeky"
      },
      {
        "command": "seeky.searchWordUnderCursor",
        "title": "Search Word Under Cursor",
        "category": "Seeky"
      }
    ],
    "keybindings": [
      {
        "command": "seeky.grep",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g",
        "when": "!terminalFocus"
      },
      {
        "command": "seeky.findFiles",
        "key": "ctrl+shift+alt+p",
        "mac": "cmd+shift+alt+p",
        "when": "!terminalFocus"
      },
      {
        "command": "seeky.searchWordUnderCursor",
        "key": "ctrl+shift+h",
        "mac": "cmd+shift+h",
        "when": "editorFocus"
      }
    ],
    "configuration": {
      "title": "Seeky Configuration",
      "properties": {
        "seeky.maxResults": {
          "type": "number",
          "default": 200,
          "description": "Maximum number of search results to display."
        },
        "seeky.fontFamily": {
          "type": "string",
          "default": "Monaspace Neon",
          "enum": [
            "Monaspace Argon",
            "Monaspace Krypton",
            "Monaspace Neon",
            "Monaspace Radon",
            "Monaspace Xenon",
            "System Default"
          ],
          "description": "The font family used in the Seeky modal."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "biome lint .",
    "compile": "tsc -p ./ --noEmit",
    "package": "vsce package"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@fontsource/monaspace-argon": "^5.2.5",
    "@fontsource/monaspace-krypton": "^5.2.5",
    "@fontsource/monaspace-neon": "^5.2.5",
    "@fontsource/monaspace-radon": "^5.2.5",
    "@fontsource/monaspace-xenon": "^5.2.5",
    "@tailwindcss/cli": "^4.3.0",
    "@types/node": "^20.19.41",
    "@types/vscode": "^1.95.0",
    "@vscode/codicons": "^0.0.45",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.20.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@ff-labs/fff-node": "^0.8.1",
    "shiki": "^4.0.2"
  }
}
